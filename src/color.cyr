# darshini — per-entry color (M4).
#
# Maps stat-derived file types to darshana SGR codes per ADR 0001.
# All ANSI escapes route through darshana's `tty_sgr` /
# `tty_sgr_reset` per the CLAUDE.md hard rule (no raw ANSI inline).
#
# Two-tier surface:
#   color_for_mode(mode)       — pure: mode bits → SGR code (no I/O)
#   compute_colors(entries, dir_str)
#                              — fs side: lstat + follow-stat per
#                                entry, returns parallel vec<i64>
#                                of SGR codes (0 = no color)
#   emit_colored(name, color)  — write the name bytes optionally
#                                wrapped in SGR + reset

# Map a stat mode (lstat-flavored) to the SGR foreground code per
# ADR 0001. Returns 0 when the entry should render uncolored
# (regular non-executable file). Symlinks return CYAN here —
# broken-symlink detection requires a follow-stat against the
# path, which only `compute_colors` can do.
fn color_for_mode(mode): i64 {
    var fmt = mode & S_IFMT;
    if (fmt == S_IFDIR)  { return TTY_FG_BLUE; }
    if (fmt == S_IFLNK)  { return TTY_FG_CYAN; }
    if (fmt == S_IFIFO)  { return TTY_FG_YELLOW; }
    if (fmt == S_IFSOCK) { return TTY_FG_BRIGHT_MAGENTA; }
    if (fmt == S_IFBLK)  { return TTY_FG_BRIGHT_YELLOW; }
    if (fmt == S_IFCHR)  { return TTY_FG_BRIGHT_YELLOW; }
    if (fmt == S_IFREG) {
        var x_bits = S_IXUSR | S_IXGRP | S_IXOTH;
        if ((mode & x_bits) != 0) { return TTY_FG_GREEN; }
        return 0;
    }
    return 0;
}

# Build per-entry "decoration" vecs for the listing of `entries`
# (basenames inside `dir_str`):
#   - colors  vec: parallel vec<sgr_code> per ADR 0001 (or 0)
#   - icons   vec: parallel vec<cstr glyph bytes> per ADR 0002
#                  (or 0 if stat failed)
#   - gitchrs vec: parallel vec<i64 status-char byte> per M7
#                  (or 0 when want_git == 0; ' ' = 32 when ctx
#                  is non-null but the lookup failed)
# Each vec is omitted if its want_ flag is 0; the returned
# 24-byte struct stores 0 for the omitted slot.
#
# Single lstat per entry — saves three separate passes.
# Symlinks pay one extra `sys_stat` for broken-target detection
# (only when want_color is on; the icon stays the link glyph
# either way; git status uses lstat-only data).
#
# Returns a 24-byte heap struct: {colors@0, icons@8, gitchrs@16}.
fn compute_decor(entries, dir_str, want_color, want_icons, git_ctx, want_mime, want_classify): i64 {
    var colors = 0;
    var icons = 0;
    var gitchrs = 0;
    var mimes = 0;
    var classifies = 0;
    var want_git = 0;
    if (git_ctx != 0) { want_git = 1; }
    if (want_color == 1)    { colors = vec_new(); }
    if (want_icons == 1)    { icons = vec_new(); }
    if (want_git == 1)      { gitchrs = vec_new(); }
    if (want_mime == 1)     { mimes = vec_new(); }
    if (want_classify == 1) { classifies = vec_new(); }
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var name = vec_get(entries, i);
        var full = path_join(dir_str, name);
        var stat_buf = alloc(144);
        var rc = lstat_path(str_data(full), stat_buf);
        var c = 0;
        var ic = 0;
        var gc = 32;
        var mm = 0;
        var cl = 0;
        if (rc >= 0) {
            var mode = load32(stat_buf + STAT_MODE);
            var fmt = mode & S_IFMT;
            if (want_color == 1) {
                if (fmt == S_IFLNK) {
                    var probe[144];
                    var rc2 = sys_stat(str_data(full), &probe);
                    if (rc2 < 0) { c = TTY_FG_RED; }
                    else { c = TTY_FG_CYAN; }
                } else {
                    c = color_for_mode(mode);
                }
            }
            if (want_icons == 1) { ic = icon_for_entry(name, mode); }
            if (want_git == 1) {
                var is_dir = 0;
                if (fmt == S_IFDIR) { is_dir = 1; }
                var mtime = load64(stat_buf + STAT_MTIME);
                var size = load64(stat_buf + STAT_SIZE);
                gc = git_status_for(git_ctx, name, is_dir, mtime, size);
            }
            if (want_mime == 1) {
                mm = mime_for_entry(str_data(full), name, mode);
            }
            if (want_classify == 1) {
                cl = classify_indicator(mode);
            }
        } else {
            if (want_mime == 1) { mm = "application/octet-stream"; }
        }
        if (want_color == 1)    { vec_push(colors, c); }
        if (want_icons == 1)    { vec_push(icons, ic); }
        if (want_git == 1)      { vec_push(gitchrs, gc); }
        if (want_mime == 1)     { vec_push(mimes, mm); }
        if (want_classify == 1) { vec_push(classifies, cl); }
        i = i + 1;
    }
    var r = alloc(40);
    store64(r + 0, colors);
    store64(r + 8, icons);
    store64(r + 16, gitchrs);
    store64(r + 24, mimes);
    store64(r + 32, classifies);
    return r;
}

# Write `name` bytes to stdout with full decoration: optional
# git status char (M7), optional icon (M5), optional color (M4).
# Emission order before the name: `<git><space><icon><space>`
# (each pair only emitted when its budget is non-zero).
# Color SGR wrap envelopes ALL prefixed decoration so the
# status / icon takes the name's color.
#
# `color == 0` skips the SGR. `icon == 0` skips the icon glyph
# (and emits 2 spaces of padding when `icon_pad > 0` to keep
# column alignment for stat-failed entries). `git_char == 0`
# is the same shape for the git column (emits 2 spaces when
# `git_pad > 0` and char is 0).
#
# All four pad params (color is implicit, others explicit) are
# 0 when the corresponding decoration is globally disabled.
fn emit_decorated(name, color, icon, icon_pad, git_char, git_pad, classify_char, classify_pad): i64 {
    if (color != 0) { tty_sgr(color); }
    if (git_pad > 0) {
        if (git_char != 0) {
            var cb[1];
            store8(&cb, git_char);
            sys_write(STDOUT_FD, &cb, 1);
            sys_write(STDOUT_FD, " ", 1);
        } else {
            sys_write(STDOUT_FD, "  ", 2);
        }
    }
    if (icon != 0) {
        sys_write(STDOUT_FD, icon, strlen(icon));
        sys_write(STDOUT_FD, " ", 1);
    } else { if (icon_pad > 0) {
        sys_write(STDOUT_FD, "  ", 2);
    } }
    sys_write(STDOUT_FD, str_data(name), str_len(name));
    # v1.1 -F classify indicator: trailing 1-char suffix (or
    # space if `-F` is on but the entry's mode has no indicator —
    # keeps column alignment).
    if (classify_pad > 0) {
        if (classify_char != 0) {
            var cb2[1];
            store8(&cb2, classify_char);
            sys_write(STDOUT_FD, &cb2, 1);
        } else {
            sys_write(STDOUT_FD, " ", 1);
        }
    }
    if (color != 0) { tty_sgr_reset(); }
    return 0;
}

# Back-compat shim for callers that still want the no-decoration
# (or color-only) path — most of the long-format / non-listing
# emit paths.
fn emit_colored(name, color): i64 {
    return emit_decorated(name, color, 0, 0, 0, 0, 0, 0);
}
