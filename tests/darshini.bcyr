# darshini benchmarks (M9 bench baseline).
#
# Measures the algorithmic hot paths exercised by every listing:
# sort_entries, pick_cols, _columns_total_width, and per-entry
# decoration picks (color_for_mode, icon_for_entry, mime_for_ext).
# Filesystem I/O (dir_list, lstat) intentionally excluded — those
# vary with filesystem state + kernel cache; we benchmark the
# code we own.
#
# Numbers captured to docs/benchmarks.md per the M9 audit.
#
# Pattern: bench_new → bench_batch_start → tight loop →
# bench_batch_stop → bench_report. For sub-1us ops use
# batch_size >= 1000 to amortize clock_gettime overhead
# (~240 ns per start/stop pair on x86_64 Linux).

include "src/walk.cyr"
include "src/icons.cyr"
include "src/mime.cyr"
include "src/color.cyr"
include "src/render.cyr"
include "src/columns.cyr"

# Synthesize a vec<Str> of `n` 8-char uniform names ("name0000",
# "name0001", …). Mirrors the M3 "uniform 8-char" test fixture
# so bench numbers align with the test assertions.
fn make_uniform_vec(n): i64 {
    var v = vec_new();
    var i = 0;
    while (i < n) {
        var nb = alloc(9);
        store8(nb, 110); store8(nb + 1, 97); store8(nb + 2, 109); store8(nb + 3, 101);  # "name"
        store8(nb + 4, 48 + i / 1000);
        store8(nb + 5, 48 + (i / 100) % 10);
        store8(nb + 6, 48 + (i / 10) % 10);
        store8(nb + 7, 48 + i % 10);
        store8(nb + 8, 0);
        vec_push(v, str_clone(str_from(nb)));
        i = i + 1;
    }
    return v;
}

# Reversed variant — worst case for insertion sort. Sort_entries
# walks from i=1 to n shifting each element to the front.
fn make_reversed_vec(n): i64 {
    var v = vec_new();
    var i = n - 1;
    var safety = n;
    while (safety > 0) {
        var nb = alloc(9);
        store8(nb, 110); store8(nb + 1, 97); store8(nb + 2, 109); store8(nb + 3, 101);
        store8(nb + 4, 48 + i / 1000);
        store8(nb + 5, 48 + (i / 100) % 10);
        store8(nb + 6, 48 + (i / 10) % 10);
        store8(nb + 7, 48 + i % 10);
        store8(nb + 8, 0);
        vec_push(v, str_clone(str_from(nb)));
        i = i - 1;
        safety = safety - 1;
    }
    return v;
}

# Run sort_entries once on a fresh copy of `template`. Returns 0.
fn bench_sort_once(template, n): i64 {
    # Clone the vec so each iter gets fresh data (sort is in-place).
    var v = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(v, vec_get(template, i));
        i = i + 1;
    }
    sort_entries(v);
    return 0;
}

fn main(): i64 {
    alloc_init();

    # === sort_entries: best case (already sorted) ===
    var sorted_5    = make_uniform_vec(5);
    var sorted_100  = make_uniform_vec(100);
    var sorted_1000 = make_uniform_vec(1000);

    var b1 = bench_new("sort_entries best=5");
    bench_batch_start(b1);
    var i = 0;
    while (i < 100000) { bench_sort_once(sorted_5, 5); i = i + 1; }
    bench_batch_stop(b1, 100000);
    bench_report(b1);

    var b2 = bench_new("sort_entries best=100");
    bench_batch_start(b2);
    i = 0;
    while (i < 10000) { bench_sort_once(sorted_100, 100); i = i + 1; }
    bench_batch_stop(b2, 10000);
    bench_report(b2);

    var b3 = bench_new("sort_entries best=1000");
    bench_batch_start(b3);
    i = 0;
    while (i < 1000) { bench_sort_once(sorted_1000, 1000); i = i + 1; }
    bench_batch_stop(b3, 1000);
    bench_report(b3);

    # === sort_entries: worst case (reversed) ===
    var rev_100  = make_reversed_vec(100);
    var rev_1000 = make_reversed_vec(1000);

    var b4 = bench_new("sort_entries worst=100");
    bench_batch_start(b4);
    i = 0;
    while (i < 1000) { bench_sort_once(rev_100, 100); i = i + 1; }
    bench_batch_stop(b4, 1000);
    bench_report(b4);

    var b5 = bench_new("sort_entries worst=1000");
    bench_batch_start(b5);
    i = 0;
    while (i < 100) { bench_sort_once(rev_1000, 1000); i = i + 1; }
    bench_batch_stop(b5, 100);
    bench_report(b5);

    # === pick_cols at typical TTY widths ===
    var b6 = bench_new("pick_cols 1k@80 no-decor");
    bench_batch_start(b6);
    i = 0;
    while (i < 10000) { pick_cols(sorted_1000, 80, 0); i = i + 1; }
    bench_batch_stop(b6, 10000);
    bench_report(b6);

    var b7 = bench_new("pick_cols 1k@200 icons+git");
    bench_batch_start(b7);
    i = 0;
    while (i < 10000) { pick_cols(sorted_1000, 200, 4); i = i + 1; }
    bench_batch_stop(b7, 10000);
    bench_report(b7);

    # === per-entry decoration picks ===
    var name_md = str_from("README.md");
    var name_cyr = str_from("main.cyr");
    var mode_dir = 0x41ED;
    var mode_reg = 0x81A4;

    var b8 = bench_new("color_for_mode (dir)");
    bench_batch_start(b8);
    i = 0;
    while (i < 1000000) { color_for_mode(mode_dir); i = i + 1; }
    bench_batch_stop(b8, 1000000);
    bench_report(b8);

    var b9 = bench_new("icon_for_entry .cyr");
    bench_batch_start(b9);
    i = 0;
    while (i < 100000) { icon_for_entry(name_cyr, mode_reg); i = i + 1; }
    bench_batch_stop(b9, 100000);
    bench_report(b9);

    var b10 = bench_new("mime_for_entry .md");
    bench_batch_start(b10);
    i = 0;
    while (i < 100000) { mime_for_entry("README.md", name_md, mode_reg); i = i + 1; }
    bench_batch_stop(b10, 100000);
    bench_report(b10);

    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
