ts = "¯İ¿"            # devicon typescript
tsx = "¯Ş║"           # devicon react (jsx/tsx convention)
jsx = "¯Ş║"

# Systems / lower-level Ôåô
c = "¯İŞ"             # devicon c
h = "¯İŞ"
cpp = "¯İØ"           # devicon c++
hpp = "¯İØ"
rs = "¯Ş¿"            # devicon rust
go = "¯İĞ"            # devicon go
zig = "´äí"           # generic ÔÇö no zig-specific glyph in baseline NF
asm = "´äí"
s = "´äí"             # ASM (.s)

# Scripting Ôåô
