# darshini test suite — M1 + M2 + M3 + M4.
# Stdlib auto-included via cyrius.cyml.
#
# M1 coverage (carried forward from v0.2.0):
#   * lower_byte, str_lt_ci, sort_entries
#   * classify_path, check_dir_readable
#
# M2 coverage (new at v0.3.0):
#   * format_perms — every file-type char, all rwx triples,
#     setuid/setgid/sticky upper+lower variants
#   * format_size_decimal — 0, single-digit, multi-digit
#   * format_size_human — bucket boundaries (1023/1024,
#     1MB-1/1MB, etc.) + sub-1K decimal pass-through
#   * format_mtime — known epoch values → known UTC strings
#
# M3 coverage (new at v0.4.0):
#   * pick_cols — synthetic vecs sized 1, 5, 100, 1000 against
#     several term widths; degenerate widths (0, too-narrow);
#     uniform vs jagged name lengths
#   * _columns_total_width — exact byte width for known layouts
#
# M4 coverage (new at v0.5.0):
#   * color_for_mode — every file type → its ADR-0001 SGR code

include "src/walk.cyr"
include "src/color.cyr"
include "src/render.cyr"
include "src/columns.cyr"
include "src/long.cyr"

fn make_str(c): i64 {
    return str_clone(str_from(c));
}

fn vec_of3(a, b, c): i64 {
    var v = vec_new();
    vec_push(v, a);
    vec_push(v, b);
    vec_push(v, c);
    return v;
}

# Compare exactly N bytes of buf against the cstr `expected`.
# Returns 1 on match, 0 otherwise. memeq from lib/string.cyr.
fn buf_eq_cstr(buf, n, expected): i64 {
    if (n != strlen(expected)) { return 0; }
    return memeq(buf, expected, n);
}

fn main(): i64 {
    alloc_init();

    test_group("lower_byte");
    assert_eq(lower_byte(65), 97, "A -> a");
    assert_eq(lower_byte(90), 122, "Z -> z");
    assert_eq(lower_byte(97), 97, "a -> a");
    assert_eq(lower_byte(48), 48, "0 unchanged");
    assert_eq(lower_byte(64), 64, "@ unchanged (just below A)");
    assert_eq(lower_byte(91), 91, "[ unchanged (just above Z)");

    test_group("str_lt_ci");
    var a = make_str("apple");
    var b = make_str("banana");
    var a_upper = make_str("APPLE");
    var apricot = make_str("apricot");
    var app = make_str("app");
    assert_eq(str_lt_ci(a, b), 1, "apple < banana");
    assert_eq(str_lt_ci(b, a), 0, "banana not < apple");
    assert_eq(str_lt_ci(a, a), 0, "apple not < apple");
    assert_eq(str_lt_ci(a, a_upper), 0, "apple not < APPLE (case-fold equal)");
    assert_eq(str_lt_ci(a_upper, a), 0, "APPLE not < apple (case-fold equal)");
    assert_eq(str_lt_ci(a, apricot), 1, "apple < apricot");
    assert_eq(str_lt_ci(app, a), 1, "app < apple (prefix shorter)");
    assert_eq(str_lt_ci(a, app), 0, "apple not < app (prefix shorter)");

    test_group("sort_entries");
    var sorted_in = vec_of3(make_str("alpha"), make_str("beta"), make_str("gamma"));
    sort_entries(sorted_in);
    assert_eq(str_eq(vec_get(sorted_in, 0), make_str("alpha")), 1, "sorted[0] = alpha");
    assert_eq(str_eq(vec_get(sorted_in, 1), make_str("beta")), 1, "sorted[1] = beta");
    assert_eq(str_eq(vec_get(sorted_in, 2), make_str("gamma")), 1, "sorted[2] = gamma");

    var rev = vec_of3(make_str("gamma"), make_str("beta"), make_str("alpha"));
    sort_entries(rev);
    assert_eq(str_eq(vec_get(rev, 0), make_str("alpha")), 1, "reverse->[0] = alpha");
    assert_eq(str_eq(vec_get(rev, 1), make_str("beta")), 1, "reverse->[1] = beta");
    assert_eq(str_eq(vec_get(rev, 2), make_str("gamma")), 1, "reverse->[2] = gamma");

    var mixed = vec_of3(make_str("Charlie"), make_str("alpha"), make_str("Beta"));
    sort_entries(mixed);
    assert_eq(str_eq(vec_get(mixed, 0), make_str("alpha")), 1, "mixed->[0] = alpha");
    assert_eq(str_eq(vec_get(mixed, 1), make_str("Beta")), 1, "mixed->[1] = Beta (preserved case)");
    assert_eq(str_eq(vec_get(mixed, 2), make_str("Charlie")), 1, "mixed->[2] = Charlie");

    var empty = vec_new();
    sort_entries(empty);
    assert_eq(vec_len(empty), 0, "empty vec stays empty");

    var single = vec_new();
    vec_push(single, make_str("only"));
    sort_entries(single);
    assert_eq(str_eq(vec_get(single, 0), make_str("only")), 1, "single-element vec");

    test_group("classify_path");
    assert_eq(classify_path("README.md"), 0, "README.md is non-dir");
    assert_eq(classify_path("src"), 1, "src/ is dir");
    assert_eq(classify_path("./absolutely-nope-no-such-path-xyzzy"), 0 - ENOENT, "missing path -> -ENOENT");

    test_group("check_dir_readable");
    assert_eq(check_dir_readable("src"), 0, "src/ readable -> 0");
    assert_eq(check_dir_readable("./absolutely-nope-no-such-path-xyzzy"), 0 - ENOENT, "missing -> -ENOENT");

    # ============================================================
    # M2 — long-format column formatters
    # ============================================================

    test_group("format_perms");
    var pb = alloc(10);
    # Regular file, rw-r--r-- (0o100644 = 0x81A4)
    format_perms(0x81A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "-rw-r--r--"), 1, "regular 0644 -> -rw-r--r--");
    # Directory, rwxr-xr-x (0o040755 = 0x41ED)
    format_perms(0x41ED, pb);
    assert_eq(buf_eq_cstr(pb, 10, "drwxr-xr-x"), 1, "dir 0755 -> drwxr-xr-x");
    # Symlink, lrwxrwxrwx (0o120777 = 0xA1FF) — symlinks always 0777 on linux
    format_perms(0xA1FF, pb);
    assert_eq(buf_eq_cstr(pb, 10, "lrwxrwxrwx"), 1, "symlink -> lrwxrwxrwx");
    # FIFO, prw-r--r-- (0o010644 = 0x11A4)
    format_perms(0x11A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "prw-r--r--"), 1, "fifo");
    # Socket
    format_perms(0xC1A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "srw-r--r--"), 1, "socket");
    # Block dev
    format_perms(0x61A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "brw-r--r--"), 1, "block dev");
    # Char dev
    format_perms(0x21A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "crw-r--r--"), 1, "char dev");
    # All-empty perms (rare but valid)
    format_perms(0x8000, pb);
    assert_eq(buf_eq_cstr(pb, 10, "----------"), 1, "regular 0000");
    # All bits set + executable (0o100755 = 0x81ED)
    format_perms(0x81ED, pb);
    assert_eq(buf_eq_cstr(pb, 10, "-rwxr-xr-x"), 1, "regular 0755");
    # setuid + x  (0o104755 = 0x89ED) -> rws (lowercase)
    format_perms(0x89ED, pb);
    assert_eq(buf_eq_cstr(pb, 10, "-rwsr-xr-x"), 1, "setuid + x -> s");
    # setuid no x (0o104644 = 0x89A4) -> rwS (uppercase)
    format_perms(0x89A4, pb);
    assert_eq(buf_eq_cstr(pb, 10, "-rwSr--r--"), 1, "setuid no x -> S");
    # setgid + x (0o102755 = 0x85ED) -> rws on group
    format_perms(0x85ED, pb);
    assert_eq(buf_eq_cstr(pb, 10, "-rwxr-sr-x"), 1, "setgid + x -> s");
    # sticky + x on other (0o041777 = 0x43FF) -> rwt (e.g. /tmp)
    format_perms(0x43FF, pb);
    assert_eq(buf_eq_cstr(pb, 10, "drwxrwxrwt"), 1, "sticky + x -> t (/tmp shape)");
    # sticky no x on other (0o041776 = 0x43FE) -> rwT
    format_perms(0x43FE, pb);
    assert_eq(buf_eq_cstr(pb, 10, "drwxrwxrwT"), 1, "sticky no x -> T");

    test_group("format_size_decimal");
    var sb = alloc(32);
    assert_eq(format_size_decimal(0, sb), 1, "0 -> 1 byte");
    assert_eq(buf_eq_cstr(sb, 1, "0"), 1, "0 -> '0'");
    assert_eq(format_size_decimal(7, sb), 1, "7 -> 1 byte");
    assert_eq(buf_eq_cstr(sb, 1, "7"), 1, "7 -> '7'");
    assert_eq(format_size_decimal(42, sb), 2, "42 -> 2 bytes");
    assert_eq(buf_eq_cstr(sb, 2, "42"), 1, "42 -> '42'");
    assert_eq(format_size_decimal(1024, sb), 4, "1024 -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1024"), 1, "1024 -> '1024'");
    assert_eq(format_size_decimal(12345678, sb), 8, "12345678 -> 8 bytes");
    assert_eq(buf_eq_cstr(sb, 8, "12345678"), 1, "12345678 -> '12345678'");

    test_group("format_size_human");
    # < 1024 → decimal pass-through
    assert_eq(format_size_human(0, sb), 1, "0 human -> 1 byte");
    assert_eq(buf_eq_cstr(sb, 1, "0"), 1, "0 -> '0'");
    assert_eq(format_size_human(1023, sb), 4, "1023 -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1023"), 1, "1023 -> '1023'");
    # 1024 → 1.0K
    assert_eq(format_size_human(1024, sb), 4, "1024 -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1.0K"), 1, "1024 -> '1.0K'");
    # 1843 → 1.7K (1843/1024 ≈ 1.8 — int truncation gives 1.7)
    assert_eq(format_size_human(1843, sb), 4, "1843 -> '1.7K' shape");
    assert_eq(buf_eq_cstr(sb, 4, "1.7K"), 1, "1843 -> '1.7K'");
    # 1048575 (1MB-1) → 1023.9K (7 chars: 4 digits + . + 1 digit + K)
    assert_eq(format_size_human(1048575, sb), 7, "1MB-1 -> 7 bytes");
    assert_eq(buf_eq_cstr(sb, 7, "1023.9K"), 1, "1MB-1 -> '1023.9K'");
    # 1048576 → 1.0M
    assert_eq(format_size_human(1048576, sb), 4, "1MB -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1.0M"), 1, "1MB -> '1.0M'");
    # 1073741824 → 1.0G
    assert_eq(format_size_human(1073741824, sb), 4, "1GB -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1.0G"), 1, "1GB -> '1.0G'");
    # 1099511627776 → 1.0T
    assert_eq(format_size_human(1099511627776, sb), 4, "1TB -> 4 bytes");
    assert_eq(buf_eq_cstr(sb, 4, "1.0T"), 1, "1TB -> '1.0T'");

    test_group("format_mtime");
    var mb = alloc(16);
    # Epoch 0 — Unix birth
    format_mtime(0, mb);
    assert_eq(buf_eq_cstr(mb, 16, "1970-01-01 00:00"), 1, "epoch 0 -> 1970-01-01 00:00");
    # Epoch 1234567890 — '09 02 13 23:31:30 UTC (drop seconds)
    format_mtime(1234567890, mb);
    assert_eq(buf_eq_cstr(mb, 16, "2009-02-13 23:31"), 1, "1234567890 -> 2009-02-13 23:31");
    # Epoch 1700000000 — 2023-11-14 22:13:20 UTC
    format_mtime(1700000000, mb);
    assert_eq(buf_eq_cstr(mb, 16, "2023-11-14 22:13"), 1, "1700000000 -> 2023-11-14 22:13");
    # Leap-year boundary: 2000-02-29 00:00:00 UTC = 951782400
    format_mtime(951782400, mb);
    assert_eq(buf_eq_cstr(mb, 16, "2000-02-29 00:00"), 1, "leap day 2000 -> 2000-02-29 00:00");

    # ============================================================
    # M3 — multi-column auto-layout
    # ============================================================

    test_group("pick_cols");
    # Degenerate inputs: empty vec / single entry / zero width.
    var empty_v = vec_new();
    assert_eq(pick_cols(empty_v, 80), 1, "empty vec -> 1 col");

    var one_v = vec_new();
    vec_push(one_v, make_str("solo"));
    assert_eq(pick_cols(one_v, 80), 1, "1 entry -> 1 col");
    assert_eq(pick_cols(one_v, 0), 1, "tw=0 -> 1 col");
    assert_eq(pick_cols(one_v, 0 - 5), 1, "tw<0 -> 1 col");

    # Five 5-char entries: "aaaaa".."eeeee". Per col needs 5+2=7 chars
    # (sep). 5 cols => 5*5 + 4*2 = 33 chars. Fits in 40 → 5 cols.
    var five = vec_new();
    vec_push(five, make_str("aaaaa"));
    vec_push(five, make_str("bbbbb"));
    vec_push(five, make_str("ccccc"));
    vec_push(five, make_str("ddddd"));
    vec_push(five, make_str("eeeee"));
    assert_eq(pick_cols(five, 40), 5, "5x5 uniform fits 5 cols at tw=40");
    # 33 is the minimum for 5 cols; at 32, 5 cols don't fit and
    # 4 cols would be a phantom layout (5 entries × 2 rows = only
    # 3 effective cols). Falls back to 3.
    assert_eq(pick_cols(five, 32), 3, "5x5 at tw=32 -> 3 cols (4-col phantom rejected)");
    # tw=10 — only one 5-char col fits at a time (5 chars; 2-col
    # would need 5+2+5=12 > 10).
    assert_eq(pick_cols(five, 10), 1, "5x5 at tw=10 -> 1 col");
    # tw=12 — 2 cols just fit (5+2+5=12).
    assert_eq(pick_cols(five, 12), 2, "5x5 at tw=12 -> 2 cols");

    # Jagged widths: one really long entry forces narrow layouts
    # even when the others are short.
    var jag = vec_new();
    vec_push(jag, make_str("a"));
    vec_push(jag, make_str("b"));
    vec_push(jag, make_str("this-is-a-very-long-entry-name"));   # 30
    vec_push(jag, make_str("c"));
    vec_push(jag, make_str("d"));
    # tw=40 — 3 cols, 2 rows: col0=[a,b]max=1, col1=[long,c]max=30,
    # col2=[d]max=1. Total = 1+2+30+2+1 = 36 ≤ 40 → 3 cols.
    # 4-col attempt is rejected (phantom — 5 entries / 2 rows = 3 eff).
    assert_eq(pick_cols(jag, 40), 3, "jagged at tw=40 -> 3 cols");
    # tw=30 — even 1 col with 30-char widest needs 30 chars; fits 1 col.
    assert_eq(pick_cols(jag, 30), 1, "jagged at tw=30 -> 1 col (widest entry alone)");

    test_group("_columns_total_width");
    # five at 5 cols, 1 row: total = 5*5 + 4*2 = 33
    assert_eq(_columns_total_width(five, 5, 5, 1), 33, "five@5x1 -> 33");
    # five at 3 cols, 2 rows: col0={a,b}max=5, col1={c,d}max=5, col2={e}max=5.
    # total = 5+2+5+2+5 = 19
    assert_eq(_columns_total_width(five, 5, 3, 2), 19, "five@3x2 -> 19");
    # five at 1 col, 5 rows: total = 5 (no separator on single col)
    assert_eq(_columns_total_width(five, 5, 1, 5), 5, "five@1x5 -> 5");

    # 1k synthetic vec of 8-char names ("name0000", "name0001", ...).
    # Hand-computed for tw=80: 1 col=8, 2=18, 3=28, ..., 8=78, 9=88.
    # → 8 cols fits, 9 doesn't.
    var kilo = vec_new();
    var ki = 0;
    while (ki < 1000) {
        var nb = alloc(9);
        store8(nb, 110); store8(nb + 1, 97); store8(nb + 2, 109);   # 'nam'
        store8(nb + 3, 101);                                          # 'e'
        store8(nb + 4, 48 + ki / 1000);                               # always '0' here
        store8(nb + 5, 48 + (ki / 100) % 10);
        store8(nb + 6, 48 + (ki / 10) % 10);
        store8(nb + 7, 48 + ki % 10);
        store8(nb + 8, 0);
        vec_push(kilo, str_clone(str_from(nb)));
        ki = ki + 1;
    }
    assert_eq(pick_cols(kilo, 80), 8, "1k uniform 8-char at tw=80 -> 8 cols");
    assert_eq(pick_cols(kilo, 88), 9, "1k uniform 8-char at tw=88 -> 9 cols");
    assert_eq(pick_cols(kilo, 200), 20, "1k uniform 8-char at tw=200 -> 20 cols");
    assert_eq(pick_cols(kilo, 7), 1, "1k uniform 8-char at tw=7 -> 1 col (name itself > tw)");

    # 100-entry vec, also uniform 8-char. Same fit math holds —
    # the # of entries shouldn't change col count for uniform widths.
    var hundred = vec_new();
    var hi = 0;
    while (hi < 100) {
        var nb2 = alloc(9);
        store8(nb2, 110); store8(nb2 + 1, 97); store8(nb2 + 2, 109);
        store8(nb2 + 3, 101);
        store8(nb2 + 4, 48 + hi / 1000);
        store8(nb2 + 5, 48 + (hi / 100) % 10);
        store8(nb2 + 6, 48 + (hi / 10) % 10);
        store8(nb2 + 7, 48 + hi % 10);
        store8(nb2 + 8, 0);
        vec_push(hundred, str_clone(str_from(nb2)));
        hi = hi + 1;
    }
    assert_eq(pick_cols(hundred, 80), 8, "100 uniform 8-char at tw=80 -> 8 cols");
    assert_eq(pick_cols(hundred, 40), 4, "100 uniform 8-char at tw=40 -> 4 cols");

    # ============================================================
    # M4 — color picker (mode bits -> ADR-0001 SGR code)
    # ============================================================

    test_group("color_for_mode");
    # Directory (any perms) -> BLUE
    assert_eq(color_for_mode(0x41ED), TTY_FG_BLUE, "dir 0755 -> BLUE");
    assert_eq(color_for_mode(0x41C0), TTY_FG_BLUE, "dir 0700 -> BLUE");
    # Symlink -> CYAN (broken detection lives in compute_colors, not here)
    assert_eq(color_for_mode(0xA1FF), TTY_FG_CYAN, "symlink -> CYAN (live; broken is compute_colors)");
    # FIFO -> YELLOW
    assert_eq(color_for_mode(0x11A4), TTY_FG_YELLOW, "fifo -> YELLOW");
    # Socket -> BRIGHT_MAGENTA
    assert_eq(color_for_mode(0xC1A4), TTY_FG_BRIGHT_MAGENTA, "socket -> BRIGHT_MAGENTA");
    # Block device -> BRIGHT_YELLOW
    assert_eq(color_for_mode(0x61A4), TTY_FG_BRIGHT_YELLOW, "blkdev -> BRIGHT_YELLOW");
    # Char device -> BRIGHT_YELLOW
    assert_eq(color_for_mode(0x21A4), TTY_FG_BRIGHT_YELLOW, "chrdev -> BRIGHT_YELLOW");
    # Regular non-executable -> 0 (no color)
    assert_eq(color_for_mode(0x81A4), 0, "regular 0644 -> 0 (no color)");
    assert_eq(color_for_mode(0x8000), 0, "regular 0000 -> 0 (no color)");
    # Regular file with any exec bit -> GREEN
    assert_eq(color_for_mode(0x81ED), TTY_FG_GREEN, "regular 0755 -> GREEN");
    assert_eq(color_for_mode(0x81C0 | S_IXUSR), TTY_FG_GREEN, "regular x-by-user -> GREEN");
    assert_eq(color_for_mode(0x81C0 | S_IXGRP), TTY_FG_GREEN, "regular x-by-group -> GREEN");
    assert_eq(color_for_mode(0x81C0 | S_IXOTH), TTY_FG_GREEN, "regular x-by-other -> GREEN");
    # Setuid bit alone (no exec) on a regular file -> still 0
    # (setuid without x is unusual; we don't promote color on it,
    # we only render the 'S' in the perm string).
    assert_eq(color_for_mode(0x89A4), 0, "regular setuid no-x -> 0 (no color)");

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
