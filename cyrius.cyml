[package]
name = "darshini"
version = "${file:VERSION}"
description = "darshini — eza-equivalent pretty file listing (colors, icons, git-status, tree view, mime-type recognition). Sanskrit दर्शिनी: she who shows. Sibling-not-competitor to kriya's minimal ls."
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.0.0"

[build]
entry = "src/main.cyr"
test = "src/test.cyr"
output = "darshini"

[deps]
stdlib = ["string", "fmt", "alloc", "io", "vec", "str", "syscalls", "args", "fs", "chrono", "assert", "bench"]

# darshana — TTY/ANSI/cursor primitives. Per CLAUDE.md's hard rule
# (no raw ANSI inline), every color escape darshini emits routes
# through darshana's tty_sgr / tty_sgr_reset. Pinned at 0.5.3 (the
# 8/16-color named-color surface + 24-bit truecolor — we use only
# the 16-color names today). Roadmap M4 dep gate is "≥ 0.3.0";
# we're well past that.
[deps.darshana]
git = "https://github.com/MacCracken/darshana.git"
tag = "0.5.3"
modules = ["dist/darshana.cyr"]

# Future: possibly [deps.chakshu] later for AI-augmented mime-
# prediction or repo-context-aware coloring (v2.0 territory).
